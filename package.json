{
  "name": "pe-02-api",
  "version": "1.0.0",
  "private": true,
  "description": "Module 2 — a Hono + Supabase meal-log API. Fix five 'right access for the job' bugs, one gate at a time.",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "begin": "node scripts/begin.cjs",
    "unlock": "node scripts/unlock.cjs",
    "validate": "node scripts/validate_pr.cjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "tsx src/server.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "@supabase/supabase-js": "^2.110.0",
    "hono": "^4.12.27"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  },
  "allowScripts": {
    "esbuild": true,
    "fsevents": true
  }
}
